# ============================================================
# GEOPulse — Environment Variables Template
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control!
# ============================================================

# === Geotab API ===
# Create a free demo database: https://my.geotab.com/registration.html
# Click "Create a Demo Database" (not "I'm a New Customer")
GEOTAB_DATABASE=
GEOTAB_USERNAME=
GEOTAB_PASSWORD=
GEOTAB_SERVER=my.geotab.com

# === Google Gemini AI ===
# Get API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# === Google Maps Platform ===
# Note: the dashboard currently uses Leaflet (no key needed).
# map.js contains a Google Maps alternative that can be activated by
# loading maps.googleapis.com in index.html and setting this key.
GOOGLE_MAPS_API_KEY=

# === Google Cloud Text-to-Speech ===
# Enable: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# Option A — service account JSON (Journey voices, recommended):
GOOGLE_APPLICATION_CREDENTIALS=
# Option B — API key (falls back to GEMINI_API_KEY if unset):
GOOGLE_TTS_API_KEY=

# === TTS Tuning (optional — defaults shown) ===
TTS_CONNECT_TIMEOUT=5
TTS_READ_TIMEOUT=35
TTS_RETRIES=3
TTS_RETRY_BACKOFF=1.2

# === Gmail API (OAuth2, for sending driver/manager emails) ===
# Enable: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# Create OAuth2 credentials in Cloud Console
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# === Email fallback — SMTP App Password ===
# Used when Gmail OAuth2 creds are absent.
# For Gmail: https://myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=
# OR use the dedicated alias names (either works):
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# === Google Sheets / Drive (podcast + KPI publishing) ===
# Uses same GOOGLE_APPLICATION_CREDENTIALS service account
# Sheets: weekly KPI rows appended per run
GOOGLE_SHEETS_ID=
# Drive: podcast MP3 + script stored here
GOOGLE_DRIVE_FOLDER_ID=

# === Email Recipients ===
# Manager who receives the daily morning brief
MANAGER_EMAIL=
# Executive(s) who receive the podcast notification
EXEC_EMAIL=

# === LLM Provider ===
# Choose: 'gemini' (default) or 'ollama' (local, free)
LLM_PROVIDER=gemini
# Optional model override (default: gemini-2.0-flash / llama3.2)
LLM_MODEL=
# Ollama server URL (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
